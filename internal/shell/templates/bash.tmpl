# zgod shell integration for bash
# if command -v zgod >/dev/null 2>&1; then eval "$(zgod init bash)"; fi
{{if .ConfigPath}}
export ZGOD_CONFIG={{bashQuote .ConfigPath}}
{{end}}

__zgod_session_id=""
__zgod_command=""
__zgod_start_ms=""
__zgod_last_exit_code=""
__zgod_preexec_fired=""
__zgod_in_hook=""
__zgod_running_original_debug_trap=""
__zgod_original_prompt_command=""
__zgod_original_prompt_command_is_array=""
__zgod_original_prompt_command_array=()
__zgod_original_debug_trap=""
__zgod_ready=""

__zgod_has_command() {
    command -v zgod &>/dev/null
}

__zgod_init() {
    if [[ -z "$__zgod_session_id" ]]; then
        if [[ -r /proc/sys/kernel/random/uuid ]]; then
            __zgod_session_id=$(cat /proc/sys/kernel/random/uuid)
        elif command -v uuidgen &>/dev/null; then
            __zgod_session_id=$(uuidgen)
        else
            __zgod_session_id="$$-$(date +%s)"
        fi
    fi
}

__zgod_get_time_ms() {
    if [[ -n "$EPOCHREALTIME" ]]; then
        local sec=${EPOCHREALTIME%.*}
        local frac=${EPOCHREALTIME#*.}
        printf '%s%s' "$sec" "${frac:0:3}"
    else
        printf '%ss' "$(date +%s)"
    fi
}

__zgod_extract_history_command() {
    local history_line=$1
    if [[ -z "$history_line" ]]; then
        return 1
    fi

    if [[ "$history_line" =~ ^[[:space:]]*[0-9]+[[:space:]]+(.*)$ ]]; then
        printf '%s' "${BASH_REMATCH[1]}"
        return 0
    fi

    history_line=${history_line#"${history_line%%[![:space:]]*}"}
    printf '%s' "$history_line"
}

__zgod_get_history_command() {
    local history_line
    if ! [[ -o history ]]; then
        return 1
    fi

    history_line=$(HISTTIMEFORMAT= builtin history 1 2>/dev/null)
    __zgod_extract_history_command "$history_line"
}

__zgod_get_recorded_command() {
    local history_command
    history_command=$(__zgod_get_history_command)
    if [[ -n "$history_command" ]]; then
        printf '%s' "$history_command"
        return
    fi

    history_command=$(fc -ln -1 2>/dev/null)
    if [[ -n "$history_command" ]]; then
        history_command=${history_command#"${history_command%%[![:space:]]*}"}
        printf '%s' "$history_command"
        return
    fi

    printf '%s' "$__zgod_command"
}

__zgod_restore_exit_code() {
    return "$1"
}

__zgod_eval_with_exit_code() {
    local exit_code=$1
    local command=$2

    builtin eval "__zgod_restore_exit_code $exit_code"$'\n'"$command"
}

__zgod_capture_original_prompt_command() {
    local declaration
    declaration=$(declare -p PROMPT_COMMAND 2>/dev/null) || return

    if [[ "$declaration" == "declare -a "* ]]; then
        __zgod_original_prompt_command_is_array=1
        __zgod_original_prompt_command_array=("${PROMPT_COMMAND[@]}")
        return
    fi

    __zgod_original_prompt_command="$PROMPT_COMMAND"
}

__zgod_capture_original_debug_trap() {
    local trap_line=$1
    local trap_body

    if [[ -z "$trap_line" ]]; then
        return
    fi

    trap_body=${trap_line#trap -- \'}
    trap_body=${trap_body%\' DEBUG}
    __zgod_original_debug_trap="$trap_body"
}

__zgod_run_original_prompt_commands() {
    local exit_code=$1
    local prompt_command

    if [[ -n "$__zgod_original_prompt_command_is_array" ]]; then
        for prompt_command in "${__zgod_original_prompt_command_array[@]}"; do
            if [[ -z "$prompt_command" ]]; then
                continue
            fi

            __zgod_eval_with_exit_code "$exit_code" "$prompt_command"
        done

        return
    fi

    if [[ -z "$__zgod_original_prompt_command" ]]; then
        return
    fi

    __zgod_eval_with_exit_code "$exit_code" "$__zgod_original_prompt_command"
}

__zgod_run_original_debug_trap() {
    local exit_code=$1

    if [[ -z "$__zgod_original_debug_trap" ]]; then
        return "$exit_code"
    fi

    __zgod_eval_with_exit_code "$exit_code" "$__zgod_original_debug_trap"
    local trap_status=$?
    __zgod_restore_exit_code "$exit_code"

    return "$trap_status"
}

__zgod_capture_prompt_exit_code() {
    return 0
}

__zgod_preexec() {
    if [[ -z "$__zgod_ready" ]]; then
        return
    fi
    if [[ -n "$__zgod_preexec_fired" ]]; then
        return
    fi
    if [[ -n "$__zgod_in_hook" ]]; then
        return
    fi
    if [[ -n "$COMP_LINE" ]]; then
        return
    fi
    if [[ "$BASH_COMMAND" == "__zgod_prompt_command" ]]; then
        return
    fi
    if [[ "$BASH_COMMAND" == "zgod" || "$BASH_COMMAND" == zgod\ * ]]; then
        return
    fi
    if [[ "$BASH_COMMAND" == "__zgod_"* ]]; then
        return
    fi
    __zgod_preexec_fired=1
    __zgod_init
    __zgod_command=$(__zgod_get_history_command)
    if [[ -z "$__zgod_command" ]]; then
        __zgod_command="$BASH_COMMAND"
    fi
    __zgod_start_ms=$(__zgod_get_time_ms)
}

__zgod_debug_trap() {
    local exit_code=$?

    if [[ -n "$__zgod_running_original_debug_trap" ]]; then
        return "$exit_code"
    fi

    if [[ "$BASH_COMMAND" == "__zgod_capture_prompt_exit_code" ]]; then
        __zgod_last_exit_code=$exit_code
    fi

    __zgod_preexec

    if [[ -z "$__zgod_original_debug_trap" ]]; then
        return "$exit_code"
    fi

    __zgod_running_original_debug_trap=1
    __zgod_run_original_debug_trap "$exit_code"
    local trap_status=$?
    __zgod_running_original_debug_trap=""

    return "$trap_status"
}

__zgod_prompt_command() {
    local exit_code=${__zgod_last_exit_code:-$?}
    local command
    __zgod_in_hook=1

    if [[ -n "$__zgod_command" ]]; then
        command=$(__zgod_get_recorded_command)
        if [[ -n "$command" ]] && __zgod_has_command; then
            zgod record \
                --ts "$__zgod_start_ms" \
                --exit-code "$exit_code" \
                --command "$command" \
                --directory "$PWD" \
                --session "$__zgod_session_id" & disown
        fi
    fi

    __zgod_command=""
    __zgod_preexec_fired=""
    __zgod_run_original_prompt_commands "$exit_code"
    __zgod_in_hook=""

    return 0
}

__zgod_search() {
    __zgod_in_hook=1
    if ! __zgod_has_command; then
        __zgod_in_hook=""
        return
    fi
    local selected
    selected=$(zgod search --height 15 --query "$READLINE_LINE" </dev/tty)
    local rc=$?
    if [[ $rc -eq 2 ]] && [[ -n "$selected" ]]; then
        READLINE_LINE=""
        READLINE_POINT=0
        eval "$selected"
    elif [[ $rc -eq 0 ]] && [[ -n "$selected" ]]; then
        READLINE_LINE="$selected"
        READLINE_POINT=${#selected}
    fi
    __zgod_in_hook=""
}

__zgod_capture_original_prompt_command
__zgod_original_debug_trap_line_file="${TMPDIR:-/tmp}/zgod-debug-trap-$$.tmp"
builtin trap -p DEBUG > "$__zgod_original_debug_trap_line_file"
__zgod_original_debug_trap_line=$(<"$__zgod_original_debug_trap_line_file")
rm -f "$__zgod_original_debug_trap_line_file"
__zgod_capture_original_debug_trap "$__zgod_original_debug_trap_line"
trap '__zgod_debug_trap' DEBUG
PROMPT_COMMAND='__zgod_capture_prompt_exit_code; __zgod_prompt_command'

bind -x '"\C-r": __zgod_search'
__zgod_ready=1
